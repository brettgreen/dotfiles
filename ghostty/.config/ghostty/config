# Font
font-family = JetBrains Mono
font-size = 14

# Theme
theme = catppuccin-mocha

# Window
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = tabs

# Cursor
cursor-style = block
cursor-style-blink = false

# Clipboard
copy-on-select = true

# Shell integration
shell-integration = zsh
