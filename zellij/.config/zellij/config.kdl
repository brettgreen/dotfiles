theme "catppuccin-mocha"
default_layout "split"
pane_frames false
simplified_ui true
copy_on_select true

// Mouse support
mouse_mode true
scroll_buffer_size 50000

// Catppuccin themes
themes {
    catppuccin-mocha {
        bg "#585b70"
        fg "#cdd6f4"
        red "#f38ba8"
        green "#a6e3a1"
        blue "#89b4fa"
        yellow "#f9e2af"
        magenta "#f5c2e7"
        orange "#fab387"
        cyan "#89dceb"
        black "#181825"
        white "#cdd6f4"
    }
}
